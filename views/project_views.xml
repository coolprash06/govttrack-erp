<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Project Actions -->
        <record id="govttrack_project_action" model="ir.actions.act_window">
            <field name="name">Projects</field>
            <field name="res_model">govttrack.project</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="help">Manage government projects</field>
        </record>

        <record id="govttrack_project_analytics_action" model="ir.actions.act_window">
            <field name="name">Project Analytics</field>
            <field name="res_model">govttrack.project</field>
            <field name="view_mode">graph,pivot,list</field>
            <field name="help">Analyze project budgets, health, and grievance trends.</field>
        </record>

        <!-- Project Tree View -->
        <record id="govttrack_project_tree_view" model="ir.ui.view">
            <field name="name">govttrack.project.tree</field>
            <field name="model">govttrack.project</field>
            <field name="arch" type="xml">
                <list string="Projects">
                    <field name="name"/>
                    <field name="constituency_id"/>
                    <field name="category_id"/>
                    <field name="budget"/>
                    <field name="status"/>
                    <field name="delay_days"/>
                </list>
            </field>
        </record>

        <!-- Project Form View -->
        <record id="govttrack_project_form_view" model="ir.ui.view">
            <field name="name">govttrack.project.form</field>
            <field name="model">govttrack.project</field>
            <field name="arch" type="xml">
                <form string="Project">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="draft,submitted,under_review,approved,in_progress,completed,rejected,closed" options="{'clickable': '1'}"/>
                        <button name="action_submit" string="Submit" type="object" invisible="status != 'draft'" class="btn-primary"/>
                        <button name="action_review" string="Under Review" type="object" invisible="status != 'submitted'" class="btn-info"/>
                        <button name="action_approve" string="Approve" type="object" invisible="status not in ('submitted', 'under_review')" class="btn-success"/>
                        <button name="action_reject" string="Reject" type="object" invisible="status not in ('draft', 'submitted', 'under_review')" class="btn-secondary"/>
                        <button name="action_start" string="Start Work" type="object" invisible="status != 'approved'" class="btn-success"/>
                        <button name="action_draft" string="Reset to Draft" type="object" invisible="status in ('draft', 'completed', 'closed')" class="btn-secondary"/>
                        <button name="action_complete" string="Mark Complete" type="object" invisible="status != 'in_progress'" class="btn-success"/>
                        <button name="action_close" string="Close" type="object" invisible="status not in ('completed', 'rejected')" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                            <p class="o_text_muted"><field name="category_id"/> • <field name="constituency_id"/></p>
                        </div>

                        <!-- Accountability Snapshot Card -->
                        <div class="o_snapshot_card">
                            <div class="o_snapshot_row">
                                <div class="o_snapshot_item">
                                    <div class="o_snapshot_label">Progress</div>
                                    <div class="o_snapshot_value"><field name="completion_percentage"/>%</div>
                                </div>
                                <div class="o_snapshot_item">
                                    <div class="o_snapshot_label">Delay</div>
                                    <div class="o_snapshot_value o_danger" invisible="not is_delayed"><field name="delay_days"/> days</div>
                                    <div class="o_snapshot_value o_success" invisible="is_delayed">No Delay</div>
                                </div>
                                <div class="o_snapshot_item">
                                    <div class="o_snapshot_label">Grievances</div>
                                    <div class="o_snapshot_value">
                                        <field name="open_grievance_count"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <group>
                            <group string="Project Details">
                                <field name="constituency_id"/>
                                <field name="category_id"/>
                                <field name="assigned_officer_id"/>
                                <field name="priority"/>
                            </group>
                            <group string="Timeline">
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="delay_days" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group string="Financial Overview">
                                <field name="currency_id" invisible="1"/>
                                <field name="budget" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="allocated_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="spent_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="completion_percentage" readonly="1"/>
                            </group>
                            <group string="Project Status">
                                <field name="is_delayed" readonly="1"/>
                                <field name="grievance_count" readonly="1"/>
                                <field name="open_grievance_count" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page name="details" string="Description">
                                <field name="description" nolabel="1"/>
                            </page>
                            <page name="grievances" string="Grievances" invisible="grievance_count == 0">
                                <field name="grievance_ids" widget="one2many_list" nolabel="1">
                                    <list editable="top">
                                        <field name="name"/>
                                        <field name="grievance_type"/>
                                        <field name="severity"/>
                                        <field name="status"/>
                                        <field name="assigned_officer_id"/>
                                        <field name="date_submitted"/>
                                    </list>
                                </field>
                            </page>
                            <page name="progress" string="Progress Notes">
                                <field name="progress_notes" nolabel="1" placeholder="Enter progress updates..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Project Kanban View -->
        <record id="govttrack_project_kanban_view" model="ir.ui.view">
            <field name="name">govttrack.project.kanban</field>
            <field name="model">govttrack.project</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="status"/>
                    <field name="completion_percentage"/>
                    <field name="delay_days"/>
                    <field name="is_delayed"/>
                    <field name="constituency_id"/>
                    <field name="category_id"/>
                    <field name="priority"/>
                    <field name="grievance_count"/>
                    <field name="open_grievance_count"/>
                    <field name="budget"/>
                    <field name="spent_amount"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card o_govttrack_card" t-attrib-class="{'o_govttrack_card_critical': record.is_delayed.raw_value}">
                                <div class="o_govttrack_card_top_bar" t-if="record.is_delayed.raw_value">
                                    <i class="fa fa-exclamation-triangle"></i> DELAYED
                                </div>
                                <div class="oe_kanban_content">
                                    <div class="o_govttrack_card_header">
                                        <h3><field name="name"/></h3>
                                        <div class="o_govttrack_card_badges">
                                            <span class="o_badge o_badge_secondary"><i class="fa fa-map-marker"></i> <field name="constituency_id"/></span>
                                            <span class="o_badge o_badge_info"><i class="fa fa-folder-open"></i> <field name="category_id"/></span>
                                        </div>
                                    </div>

                                    <div class="o_govttrack_card_indicators">
                                        <!-- Removed Health Status -->
                                    </div>

                                    <div class="o_govttrack_card_progress">
                                        <div class="o_progress_label">Completion</div>
                                        <div class="o_progress_bar">
                                            <div class="o_progress_fill" t-attrib-style="'width: ' + record.completion_percentage.value + '%'"></div>
                                        </div>
                                        <div class="o_progress_value"><field name="completion_percentage"/>%</div>
                                    </div>

                                    <div class="o_govttrack_card_metrics">
                                        <div class="o_metric_item" t-if="record.is_delayed.raw_value">
                                            <span class="o_metric_label">Delay</span>
                                            <span class="o_metric_value o_metric_danger"><field name="delay_days"/> days</span>
                                        </div>
                                        <div class="o_metric_item">
                                            <span class="o_metric_label">Grievances</span>
                                            <span class="o_metric_value" t-if="record.open_grievance_count.value > 0" t-attrib-class="'o_metric_warning'"><field name="open_grievance_count"/> open</span>
                                            <span class="o_metric_value" t-if="record.open_grievance_count.value == 0">None</span>
                                        </div>
                                    </div>

                                    <div class="o_govttrack_card_financial">
                                        <div class="o_financial_row">
                                            <span class="o_financial_label">BUDGET</span>
                                            <span class="o_financial_value">₹<field name="budget_short"/></span>
                                        </div>
                                        <div class="o_financial_row">
                                            <span class="o_financial_label">SPENT</span>
                                            <span class="o_financial_value">₹<field name="spent_amount_short"/></span>
                                        </div>
                                    </div>

                                    <div class="o_govttrack_card_status" t-if="record.priority.raw_value">
                                        <span class="o_badge o_badge_priority" t-attrib-class="'o_badge_' + record.priority.raw_value">
                                            <field name="priority"/> Priority
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Project Graph View -->
        <record id="govttrack_project_graph_view" model="ir.ui.view">
            <field name="name">govttrack.project.graph</field>
            <field name="model">govttrack.project</field>
            <field name="arch" type="xml">
                <graph string="GovtTrack Governance Dashboard">
                    <field name="category_id" type="row"/>
                    <field name="status" type="col"/>
                    <field name="budget" type="measure"/>
                    <field name="spent_amount" type="measure"/>
                    <field name="open_grievance_count" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Project Pivot View -->
        <record id="govttrack_project_pivot_view" model="ir.ui.view">
            <field name="name">govttrack.project.pivot</field>
            <field name="model">govttrack.project</field>
            <field name="arch" type="xml">
                <pivot string="Project Analytics">
                    <field name="status" type="row"/>
                    <field name="budget" type="measure"/>
                    <field name="spent_amount" type="measure"/>
                    <field name="completion_percentage" type="measure"/>
                </pivot>
            </field>
        </record>
    </data>
</odoo>
